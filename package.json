{
  "name": "open-aeo",
  "version": "1.0.0",
  "description": "An open-source MCP server for Answer Engine Optimization (AEO) monitoring.",
  "main": "dist/index.js",
  "bin": {
    "open-aeo": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "openai": "^4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "author": "brgv-code/open-aeo",
  "license": "MIT"
}
