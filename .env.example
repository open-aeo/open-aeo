# Required — get yours at https://www.perplexity.ai/api-platform
PERPLEXITY_API_KEY=your-key-here

# Optional — enables the ChatGPT answer engine (OpenAI Responses API + web search).
# When set, checks run against ChatGPT in addition to Perplexity.
# OPENAI_API_KEY=your-openai-key-here

# Optional — how many times aeo_check samples each query per engine (citation
# rate). Default 3, max 10. Higher = more reliable numbers, more API cost.
# OPEN_AEO_SAMPLES=3

# Optional — override default storage location (~/.open-aeo/history.json)
# OPEN_AEO_STORE_PATH=/custom/path/history.json
