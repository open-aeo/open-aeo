{
  "mcpServers": {
    "open-aeo": {
      "command": "node",
      "args": ["/Users/username/path-to-repo/open-aeo/dist/index.js"],
      "env": {
        "PERPLEXITY_API_KEY": "pplx-your-perplexity-api-key-here"
      }
    }
  },
  "preferences": {
    "coworkScheduledTasksEnabled": false,
    "ccdScheduledTasksEnabled": false,
    "coworkWebSearchEnabled": true,
    "sidebarMode": "chat"
  }
}
